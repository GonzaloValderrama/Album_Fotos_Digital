rules_version = '2';

// Permite a cualquier usuario leer si isPublic = true. 
// Para settings, permitelo siempre leer.
// Solo ggonzalovalderrama@gmail.com puede crear/modificar/borrar.

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para determinar si es dueño (SuperAdmin)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'ggonzalovalderrama@gmail.com';
    }

    // Configuración global de diseño
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Álbumes
    match /albums/{albumId} {
      // Público si isPublic es true, o visible para el dueño / superadmin
      allow read: if resource.data.isPublic == true || isSuperAdmin() || (request.auth != null && resource.data.ownerId == request.auth.uid) || (request.auth != null && !("ownerId" in resource.data));
      // Permitir crear si se asignan como dueños
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      // Actualizar / borrar si eran dueños
      allow update, delete: if isSuperAdmin() || (request.auth != null && resource.data.ownerId == request.auth.uid) || (request.auth != null && !("ownerId" in resource.data));
    }

    // Fotos (Lectura libre guiada por el frontend, creación protegida, borrado propietario)
    match /photos/{photoId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSuperAdmin() || (request.auth != null && resource.data.ownerId == request.auth.uid) || (request.auth != null && !("ownerId" in resource.data));
    }
  }
}
